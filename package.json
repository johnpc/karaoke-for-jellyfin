{
  "name": "karaoke-for-jellyfin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run kill-server && node server.js",
    "dev:next": "next dev --turbopack",
    "build": "next build",
    "kill-server": "pkill -f \"node.*server.js\" || true",
    "build:android-tv": "node scripts/build-tv-apk.js",
    "start": "NODE_ENV=production node server.js",
    "start:next": "next start",
    "lint": "lint-staged",
    "lint:check": "eslint src/ --quiet",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:crap": "node scripts/crap-check.js",
    "test:acceptance": "npx bddgen && npx playwright test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@jellyfin/sdk": "^0.11.0",
    "@types/qrcode": "^1.5.5",
    "next": "16.1.0",
    "node-fetch": "^2.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@cypress/code-coverage": "^3.14.5",
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-istanbul": "^4.1.8",
    "cypress": "^14.5.3",
    "cypress-real-events": "^1.14.0",
    "eslint": "^9",
    "eslint-config-next": "15.4.2",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.1.2",
    "playwright": "^1.60.0",
    "playwright-bdd": "^9.1.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
